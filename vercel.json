{
  "version": 2,
  "builds": [
    { "src": "docs/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/releases", "dest": "/docs/releases.html" },
    { "src": "/releases.html", "dest": "/docs/releases.html" },
    { "src": "/(.*)", "dest": "/docs/$1" },
    { "src": "/", "dest": "/docs/index.html" }
  ]
}
